{
  "license": "MIT",
  "repository": "https://github.com/cezaraugusto/prefers-yarn.git",
  "name": "prefers-yarn",
  "version": "2.0.0",
  "description": "Detect the package manager (npm, yarn, pnpm, bun) a project prefers: user-agent, lockfile, packageManager field, corepack, and Windows-safe command resolution.",
  "homepage": "https://www.npmjs.com/package/prefers-yarn",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "publish:provenance": "np major --no-tests --any-branch --yolo --message 'release: %s' --provenance",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "publishConfig": {
    "provenance": true
  },
  "author": "Cezar Augusto <boss@cezaraugusto.net> (https://cezaraugusto.net)",
  "keywords": [
    "package-manager",
    "package-manager-detection",
    "detect",
    "npm",
    "yarn",
    "pnpm",
    "bun",
    "corepack",
    "lockfile",
    "user-agent",
    "install-command",
    "cli",
    "nodejs",
    "windows"
  ],
  "devDependencies": {
    "@rslib/core": "^0.6.9",
    "@types/node": "^22.8.1",
    "eslint": "^10.5.0",
    "eslint-config-auditor": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@9.9.0",
  "bugs": "https://github.com/cezaraugusto/prefers-yarn/issues"
}
